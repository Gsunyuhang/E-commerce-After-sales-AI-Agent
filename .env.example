# ============================================
# 电商售后智能处理 Agent - 环境配置模板
# 复制此文件为 .env 并填入实际值
# ============================================

# --- 通义千问 API 配置 ---
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# --- 模型配置 ---
LLM_MODEL_NAME=qwen-plus
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2048
EMBEDDING_MODEL_NAME=text-embedding-v2

# --- 数据库配置 ---
SQLITE_DB_PATH=data/ecommerce_agent.db

# --- 向量库配置 ---
CHROMA_PERSIST_DIR=data/chroma_db
CHROMA_COLLECTION_NAME=after_sales_policy

# --- 知识库配置 ---
KNOWLEDGE_BASE_DIR=data/knowledge_base
CHUNK_SIZE=500
CHUNK_OVERLAP=50
RETRIEVAL_TOP_K=3

# --- 阈值参数 ---
# 检索置信度阈值，低于此值标记为知识缺失
RETRIEVAL_CONFIDENCE_THRESHOLD=0.65
# 意图识别置信度阈值
INTENT_CONFIDENCE_THRESHOLD=0.7
# 人工转接置信度阈值
HUMAN_HANDOFF_THRESHOLD=0.5

# --- 多轮记忆配置 ---
MEMORY_WINDOW_SIZE=6
MEMORY_SUMMARY_INTERVAL=3

# --- 日志配置 ---
LOG_LEVEL=INFO
LOG_DIR=logs

# --- 服务配置 ---
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_PORT=8501
